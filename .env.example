# ════════════════════════════════════════
# Pulse-Chennai Environment Configuration
# ════════════════════════════════════════
# FILL IN ALL VALUES BELOW

# ── Supabase (Free Tier) ──
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_KEY=your_service_role_key

# ── Upstash Redis (Free Tier) ──
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Google Gemini AI ──
GEMINI_API_KEY=your_gemini_api_key

# ── Frontend (Vite — prefix with VITE_) ──
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key
VITE_API_BASE=http://localhost:8000

# ── Legacy (kept for compatibility, not used in free tier) ──
# DATABASE_URL=postgresql+asyncpg://pulse:pulse_secret@localhost:5432/pulse_chennai
# REDIS_URL=redis://localhost:6379/0
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# TOMTOM_API_KEY=

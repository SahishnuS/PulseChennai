# ════════════════════════════════════════════
# Pulse-Chennai Environment Configuration
# ════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── PostgreSQL (Supabase or local PostGIS) ──
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── Redis (Speed Layer cache) ──
REDIS_URL=redis://localhost:6379/0

# ── Kafka (Event streaming) ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_GPS=bus-gps-pings
KAFKA_TOPIC_PASSENGER=passenger-pings
KAFKA_CONSUMER_GROUP=pulse-chennai-consumer

# ── TomTom Traffic API ──
# Get a free key at https://developer.tomtom.com (2,500 req/day free)
TOMTOM_API_KEY=4IBv5SKD0uHDFTGsvn733LR1XpQc3AZr

# ── Application Settings ──
H3_RESOLUTION=9
GHOST_BUS_THRESHOLD=0.3
TOMTOM_REFRESH_INTERVAL=120
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-string

# ── GNN Model ──
GNN_WEIGHTS_PATH=ml/weights/spatial_gnn_best.pt

# ── Docker PostgreSQL (only if using docker-compose) ──
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse_secret
POSTGRES_DB=pulse_chennai
